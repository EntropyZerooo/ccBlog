---
import { Icon } from "astro-icon/components";
import CollectionPreview from "./CollectionPreview.astro";
import { collectionsConfig } from "@/config";
import type { Tag } from "@/utils/content-utils";
import { url } from "@/utils/url-utils";

interface Props {
	tags: Tag[];
}

const { tags } = Astro.props;
const topTags = tags.slice(0, 14);
---

<aside id="sidebar" class="animate flex flex-col gap-8">
	<div>
		<h2 class="mb-4 flex items-center text-lg font-semibold">
			<Icon name="material-symbols:inventory-2-outline" class="mr-2 text-xl" />
			Collections
		</h2>
		<ul class="flex flex-col gap-1">
			{collectionsConfig.slice(0, 5).map((collection) => (
				<li>
					<CollectionPreview collection={collection} />
				</li>
			))}
		</ul>
		<span class="mt-4 block text-end text-sm">
			<a
				href={url("/archive/")}
				class="text-muted-foreground hover:text-[hsl(var(--primary-hsl))]"
			>
				View all →
			</a>
		</span>
	</div>

	{
		topTags.length > 0 && (
			<div>
				<h2 class="mb-4 flex items-center text-lg font-semibold">
					<Icon name="material-symbols:label-outline" class="mr-2 text-xl" />
					Tags
				</h2>
				<ul class="flex flex-wrap gap-2">
					{topTags.map((tag) => (
						<li>
							<a
								href={url(`/archive/?tag=${encodeURIComponent(tag.name)}`)}
								class="axi-tag-pill"
							>
								{tag.name}
							</a>
						</li>
					))}
				</ul>
				<span class="mt-4 block text-end text-sm">
					<a
						href={url("/archive/")}
						class="text-muted-foreground hover:text-[hsl(var(--primary-hsl))]"
					>
						View all →
					</a>
				</span>
			</div>
		)
	}
</aside>
